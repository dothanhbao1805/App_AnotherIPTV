<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.AnotherIPTV" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <item name="android:statusBarColor">@color/bg_status_bar</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="colorPrimary">#1A3D6D</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorOnBackground">#FFFFFF</item>

        <item name="colorSurface">@color/bg_main</item>
        <item name="colorSurfaceVariant">@color/bg_main</item>
        <item name="android:colorBackground">@color/bg_main</item>
        <item name="android:windowBackground">@color/bg_main</item>

        <item name="switchStyle">@style/CustomSwitch</item>
    </style>

    <style name="CustomSwitch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb_color</item>
        <item name="android:track">@drawable/switch_track</item>
        <item name="android:scaleX">1.15</item>
        <item name="android:scaleY">1.15</item>
    </style>

</resources>