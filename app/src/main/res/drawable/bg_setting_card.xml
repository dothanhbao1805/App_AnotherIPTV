<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="#1A000000" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Card background -->
    <item
        android:bottom="4dp">
        <shape>
            <solid android:color="@color/bg_setting_card" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>