<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_checked="true">
        <layer-list>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="oval">
                    <solid android:color="@color/bg_thumb_checked" />
                    <size android:width="18dp" android:height="18dp" />
                    <stroke android:width="0.5dp" android:color="#20000000"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_checked="false">
        <layer-list>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="oval">
                    <solid android:color="@color/bg_thumb_un_checked" />
                    <size android:width="18dp" android:height="18dp" />
                    <stroke android:width="0.5dp" android:color="#20000000"/>
                </shape>
            </item>
        </layer-list>
    </item>

</selector>