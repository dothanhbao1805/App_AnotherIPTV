<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_main"
        app:title="@string/sub_title"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Title"
        app:navigationIcon="@drawable/ic_arrow_back">

        <TextView
            android:id="@+id/btnReset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="16dp"
            android:text="@string/text_reset"
            android:textColor="@color/sub_primary"
            android:textSize="16sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

    </androidx.appcompat.widget.Toolbar>

    <!-- Preview -->
    <LinearLayout
        android:id="@+id/cardPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        android:background="@drawable/bg_setting_card"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_eye"
                app:tint="@color/sub_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/text_preview"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <com.example.anotheriptv.utils.MaxHeightFrameLayout
            android:id="@+id/framePreviewBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:background="#1A1A1A">

            <TextView
                android:id="@+id/tvSubtitlePreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="12dp"
                android:text="@string/sample_subtitle_text"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#80000000"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

        </com.example.anotheriptv.utils.MaxHeightFrameLayout>

    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:paddingTop="0dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Font Settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_setting_card"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_font"
                        app:tint="@color/sub_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/title_font_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Font Size -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_font_size"
                            app:tint="@color/text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_font_size"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvFontSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="32.0"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <com.example.anotheriptv.utils.StepSeekBar
                        android:id="@+id/seekBarFontSize"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:max="18"
                        android:progress="2"
                        android:progressDrawable="@drawable/bg_seekbar_track"
                        android:thumb="@drawable/bg_seekbar_thumb"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:minHeight="0dp"
                        android:maxHeight="24dp"
                        />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />


                <!-- Line Height -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_line_height"
                            app:tint="@color/text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_line_height"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvLineHeightValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="1.4"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <com.example.anotheriptv.utils.StepSeekBar
                        android:id="@+id/seekBarLineHeight"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:max="18"
                        android:progress="2"
                        android:progressDrawable="@drawable/bg_seekbar_track"
                        android:thumb="@drawable/bg_seekbar_thumb"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:minHeight="0dp"
                        android:maxHeight="24dp"
                        />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <!-- Letter Spacing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_letter_spacing"
                            app:tint="@color/text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_letter_spacing"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvLetterSpacingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="0.0"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <com.example.anotheriptv.utils.StepSeekBar
                        android:id="@+id/seekBarLetterSpacing"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:max="18"
                        android:progress="2"
                        android:progressDrawable="@drawable/bg_seekbar_track"
                        android:thumb="@drawable/bg_seekbar_thumb"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:minHeight="0dp"
                        android:maxHeight="24dp"
                        />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <!-- Word Spacing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_word_spacing"
                            app:tint="@color/text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_word_spacing"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvWordSpacingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="0.0"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <com.example.anotheriptv.utils.StepSeekBar
                        android:id="@+id/seekBarWordSpacing"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:max="18"
                        android:progress="2"
                        android:progressDrawable="@drawable/bg_seekbar_track"
                        android:thumb="@drawable/bg_seekbar_thumb"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:minHeight="0dp"
                        android:maxHeight="24dp"
                        />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />


                <!-- Padding -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_padding"
                            app:tint="@color/text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_padding"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvPaddingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="24.0"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <com.example.anotheriptv.utils.StepSeekBar
                        android:id="@+id/seekBarPadding"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:max="18"
                        android:progress="2"
                        android:progressDrawable="@drawable/bg_seekbar_track"
                        android:thumb="@drawable/bg_seekbar_thumb"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:minHeight="0dp"
                        android:maxHeight="24dp"
                        />

                </LinearLayout>

            </LinearLayout>

            <!-- Color Settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_setting_card"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_palette"
                        app:tint="@color/sub_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/title_color_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/layoutTextColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_text_color"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/label_text_color"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <View
                        android:id="@+id/viewTextColor"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_color_picker_white" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/layoutBgColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_bg_color"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/label_background_color"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <View
                        android:id="@+id/viewBgColor"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_color_picker_dark" />

                </LinearLayout>

            </LinearLayout>

            <!-- Style Settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:orientation="vertical"
                android:background="@drawable/bg_setting_card"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_style"
                        app:tint="@color/sub_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/title_style_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_bold"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/label_font_weight"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <Spinner
                        android:id="@+id/spinnerFontWeight"
                        android:layout_width="130dp"
                        android:layout_height="40dp"
                        style="@style/SpinnerStyle"
                        android:entries="@array/font_weight_options" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_align_center"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/label_text_alignment"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <Spinner
                        android:id="@+id/spinnerTextAlignment"
                        android:layout_width="130dp"
                        android:layout_height="40dp"
                        style="@style/SpinnerStyle"
                        android:entries="@array/text_alignment_options" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>