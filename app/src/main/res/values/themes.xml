<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AnotherIPTV" parent="Base.Theme.AnotherIPTV" />

    <style name="Base.Theme.AnotherIPTV" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <item name="android:windowBackground">@color/bg_main</item>

        <item name="colorPrimary">#1A3D6D</item>
    </style>

    <style name="TextAppearance.AnotherIPTV.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.AnotherIPTV.ChannelName" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">15sp</item> <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.AnotherIPTV.ChannelCategory" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.AnotherIPTV.BadgeLive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item> <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/badge_live_text</item>
    </style>

    <style name="DialogTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>